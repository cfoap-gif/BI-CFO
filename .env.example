# =============================================================================
# BI-CFO — Variáveis de ambiente (exemplo)
# =============================================================================
# Copie este arquivo para `.env.local` e preencha com as chaves reais do seu
# projeto Supabase. NUNCA versione `.env.local`.
#
# Onde encontrar:
#  - Supabase Dashboard → Project Settings → API
# =============================================================================

# URL pública do projeto Supabase (ex.: https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública anônima (segura para client). Permite operações limitadas por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de service_role (SECRETA — NUNCA expor no client).
# Usada apenas em scripts de seed e Server Actions administrativas.
# Ignora RLS. Trate como senha master do banco.
SUPABASE_SERVICE_ROLE_KEY=
